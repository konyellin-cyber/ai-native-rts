{
  "name": "interaction_v2",
  "description": "验证框选、移动指令、生产链路的完整交互系统，以及节点生命周期健康。包含 Worker 和 Archer 生产验证。",
  "window_mode": false,
  "covers": ["interaction"],
  "assertions": [
    "interaction_chain",
    "behavior_health",
    "archer_produced"
  ],
  "assertion_timeouts": {
    "interaction_chain": 3500,
    "archer_produced": 4000
  },
  "config_overrides": {
    "ai_opponent": {
      "attack_threshold": 99
    },
    "physics": {
      "total_frames": 7200
    }
  },
  "actions": [
    {"action": "wait_frames", "params": {"n": 60}},
    {"action": "box_select", "params": {"rect": "full_screen"}},
    {"action": "wait_frames", "params": {"n": 2}},
    {"action": "right_click", "params": {"target": "map_center"}},
    {"action": "wait_frames", "params": {"n": 600}},
    {"action": "box_select", "params": {"rect": "full_screen"}},
    {"action": "wait_frames", "params": {"n": 2}},
    {"action": "right_click", "params": {"target": "blue_spawn"}},
    {"action": "wait_frames", "params": {"n": 600}},
    {"action": "box_select", "params": {"rect": "red_hq_area"}},
    {"action": "wait_frames", "params": {"n": 5}},
    {"action": "click_button", "params": {"label": "Worker"}},
    {"action": "wait_frames", "params": {"n": 300}},
    {"action": "box_select", "params": {"rect": "red_hq_area"}},
    {"action": "wait_frames", "params": {"n": 5}},
    {"action": "click_button", "params": {"label": "Archer"}}
  ]
}
