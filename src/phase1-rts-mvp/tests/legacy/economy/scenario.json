{
  "name": "economy_v2",
  "description": "验证红方经济正循环：工人采矿→交付→生产。关闭 AI 进攻，给经济充足时间。",
  "window_mode": false,
  "covers": ["economy"],
  "assertions": [
    "hq_exists",
    "mineral_exists",
    "worker_exists",
    "worker_cycle",
    "production_flow",
    "economy_positive"
  ],
  "assertion_timeouts": {
    "worker_cycle": 1500,
    "production_flow": 2000,
    "economy_positive": 2000
  },
  "config_overrides": {
    "ai_opponent": {
      "attack_threshold": 99
    },
    "physics": {
      "total_frames": 7200
    }
  },
  "actions": [
    {"action": "wait_frames", "params": {"n": 60}},
    {"action": "box_select", "params": {"rect": "full_screen"}},
    {"action": "wait_frames", "params": {"n": 2}},
    {"action": "right_click", "params": {"target": "map_center"}}
  ]
}
