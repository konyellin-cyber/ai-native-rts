{
  "name": "visual_check",
  "description": "窗口模式视觉验证：事件驱动截图，捕获启动自动选中、生产面板弹出、框选、战斗、结束状态。",
  "assertions": [
    "hq_exists",
    "mineral_exists",
    "worker_exists",
    "ai_economy",
    "interaction_chain",
    "production_flow",
    "ai_produces",
    "worker_cycle",
    "behavior_health",
    "battle_resolution",
    "no_obstacle_penetration"
  ],
  "screenshot_on_signals": [
    "prod_panel_shown",
    "selection_rect_drawn",
    "produce_requested",
    "enqueue_result",
    "battle_first_kill",
    "game_over"
  ],
  "config_overrides": {
    "ai_opponent": {
      "attack_threshold": 2
    },
    "physics": {
      "total_frames": 7200
    }
  },
  "actions": [
    {"action": "wait_frames", "params": {"n": 60}},
    {"action": "box_select", "params": {"rect": "full_screen"}},
    {"action": "wait_frames", "params": {"n": 2}},
    {"action": "right_click", "params": {"target": "map_center"}},
    {"action": "wait_frames", "params": {"n": 300}},
    {"action": "box_select", "params": {"rect": "red_hq_area"}},
    {"action": "wait_frames", "params": {"n": 5}},
    {"action": "click_button", "params": {"label": "Worker"}},
    {"action": "wait_frames", "params": {"n": 600}},
    {"action": "box_select", "params": {"rect": "full_screen"}},
    {"action": "wait_frames", "params": {"n": 2}},
    {"action": "right_click", "params": {"target": "blue_spawn"}}
  ]
}
